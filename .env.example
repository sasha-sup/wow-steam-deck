# Steam Deck WoW server config — copy to `.env` and tweak.

# Container build args
DOCKER_USER=acore
DOCKER_USER_ID=1000
DOCKER_GROUP_ID=1000
DOCKER_IMAGE_TAG=local

# Volume bind paths (host paths, must exist)
DOCKER_VOL_ETC=/run/media/deck/SD512/wow/configs
DOCKER_VOL_LOGS=/run/media/deck/SD512/wow/logs
DOCKER_VOL_DATA=/run/media/deck/SD512/wow/data
DOCKER_VOL_ROOT=/run/media/deck/SD512/wow/server/ac
DOCKER_AC_CLIENT_FOLDER=/run/media/deck/SD512/wow/client

# Ports (local-only; bind to 127.0.0.1 in scripts/start-stack.sh)
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_SOAP_EXTERNAL_PORT=7878
DOCKER_DB_EXTERNAL_PORT=3306

# Database password (internal use only — server is bound to localhost)
DOCKER_DB_ROOT_PASSWORD=acorewotlk

# AC env file used inside containers
DOCKER_AC_ENV_FILE=conf/dist/env.ac

# Workspace root (parent of server/, client/, data/, etc.)
WOW_ROOT=/run/media/deck/SD512/wow
